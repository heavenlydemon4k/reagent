{
  "expo": {
    "name": "Bizzy",
    "slug": "bizzy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bizzy.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock your encrypted inbox data",
        "UIBackgroundModes": [
          "fetch",
          "processing",
          "remote-notification"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.bizzy.sync",
          "com.bizzy.background-fetch"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bizzy.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      }
    },
    "plugins": [
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow Bizzy to access your secure store to encrypt local data."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#c4a265",
          "sounds": ["./assets/notification-sound.wav"]
        }
      ],
      [
        "expo-background-fetch",
        {
          "startOnBoot": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bizzy-client"
      }
    }
  }
}
