# =============================================================================
# Reagent — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Providers (at least one required)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: custom base URLs
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://reagent:reagent@localhost:5432/reagent
POSTGRES_USER=reagent
POSTGRES_PASSWORD=reagent
POSTGRES_DB=reagent

# -----------------------------------------------------------------------------
# Vector + Graph
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qdrant_dev_key_change_me

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=reagent

# -----------------------------------------------------------------------------
# Messaging
# -----------------------------------------------------------------------------
NATS_URL=nats://localhost:4222

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-string-in-production

# -----------------------------------------------------------------------------
# Service URLs (for inter-service communication)
# -----------------------------------------------------------------------------
INGESTION_URL=http://localhost:8080
CLASSIFICATION_URL=http://localhost:8081
SYNC_URL=http://localhost:8082

# -----------------------------------------------------------------------------
# Client
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/chat/ws

# -----------------------------------------------------------------------------
# Model Settings
# -----------------------------------------------------------------------------
DS_SIMPLE_MODEL=gpt-4o-mini
DS_COMPLEX_MODEL=gpt-4o
DS_FALLBACK_MODEL=gpt-4o-mini
DS_MAX_TOKENS=4096
DS_LLM_TIMEOUT=30.0
