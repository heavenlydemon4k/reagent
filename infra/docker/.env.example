# ------------------------------------------------------------------------------
# Decision Stack - Local Development Environment Variables
# ------------------------------------------------------------------------------
# Copy this file to .env and update the values:
#   cp .env.example .env
# ------------------------------------------------------------------------------

# ==============================================================================
# PostgreSQL 16
# ==============================================================================
POSTGRES_USER=decision_stack
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=decision_stack

# ==============================================================================
# Redis 7.x
# ==============================================================================
# (No additional env vars needed - uses defaults)

# ==============================================================================
# Qdrant 1.8+
# ==============================================================================
QDRANT_API_KEY=qdrant_dev_key_change_me

# ==============================================================================
# Neo4j 5.x
# ==============================================================================
NEO4J_AUTH=neo4j/dev_password_change_me
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=512m
NEO4J_PAGECACHE=256m

# ==============================================================================
# NATS JetStream
# ==============================================================================
NATS_MAX_MEMORY=512
NATS_MAX_FILE=10

# ==============================================================================
# Application Settings
# ==============================================================================
# These are used by the application services to connect to infrastructure
DATABASE_URL=postgresql://decision_stack:dev_password_change_me@localhost:5432/decision_stack
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qdrant_dev_key_change_me
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dev_password_change_me
NATS_URL=nats://localhost:4222

# ==============================================================================
# Security Warnings (Development Only!)
# ==============================================================================
# - Never commit .env to version control
# - Use strong passwords in production
# - API keys should be rotated regularly
# - In production, use AWS Secrets Manager or similar
